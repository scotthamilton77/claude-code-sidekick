# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log
coverage/
packages/*/coverage/

# Dependency directories
node_modules/
.pnpm-store/

# Environment variables
.env
.credentials.json

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.worktrees/

# Local settings
settings.local.json

# OS specific
.DS_Store

# Windows Zone.Identifier files (created when copying from Windows to WSL)
*:Zone.Identifier

# DevContainer environment variables (contains secrets)
.devcontainer/.env

# Sidekick development env exclusions
.claude/hooks/sidekick/
.claude/skills/sidekick-setup/

# Sidekick backup files
*.backup.*
*.uninstall-backup.*


# TypeScript build cache (needs to be part of install)
.claude/tsc-cache/

# Node workspace outputs
packages/*/dist/
packages/*/tsconfig.tsbuildinfo

# Build artifacts in source-adjacent locations (sidekick-ui vite server)
packages/sidekick-ui/server/**/*.js
packages/sidekick-ui/server/**/*.d.ts
packages/sidekick-ui/*.tsbuildinfo
packages/sidekick-ui/vite.config.js
packages/sidekick-ui/vite.config.d.ts
packages/sidekick-ui/vitest.config.js
packages/sidekick-ui/vitest.config.d.ts

# Sync state (local-only, per-machine)
# These files are machine-specific and should not be shared across clones
.sync.lock
.jsonl.lock
sync_base.jsonl
export-state/

# Claude stuff
scheduled_tasks.lock
.playwright/
.playwright-mcp/

# Dist testing backup
packages/sidekick-dist/*.tgz
.worktrees/
worktrees/
# >>> sidekick
.sidekick/logs/
.sidekick/sessions/
.sidekick/state/
.sidekick/setup-status.json
.sidekick/.env
.sidekick/.env.local
.sidekick/sidekick*.pid
.sidekick/sidekick*.token
.sidekick/*.local.yaml
# <<< sidekick

# Dolt database files (added by bd init)
.dolt/
*.db

# beads - (added by user)
dolt*.lock

# Beads / Dolt files (added by bd init)
.beads-credential-key
