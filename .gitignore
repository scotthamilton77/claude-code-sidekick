# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log

# Dependency directories
node_modules/

# Environment variables
.env
.credentials.json

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS specific
.DS_Store

# Windows Zone.Identifier files (created when copying from Windows to WSL)
*:Zone.Identifier

# DevContainer environment variables (contains secrets)
.devcontainer/.env

# Sidekick development env exclusions (otherwise we get random files thrown in there that don't need to be versioned)
.sidekick
.claude/hooks/sidekick/

# Sidekick backup files
*.backup.*
*.uninstall-backup.*

# for now?
test-data/results/
test-data/replay-results/
test-data/topic-analysis/
# Sidekick Hook System (managed by scripts/install.sh)
# Runtime data - ignored
.sidekick/*.log
.sidekick/sessions/

# Templates, config, backups - tracked by default, uncomment to ignore
# .sidekick/README.md
# .sidekick/sidekick.conf
# .sidekick/sidekick.conf.template
# .sidekick/reminders/*.template
# .sidekick/reminders/*-reminder.txt
# *.backup.*
# *.uninstall-backup.*
# End Sidekick Hook System
