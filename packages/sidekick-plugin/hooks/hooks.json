{
  "hooks": {
    "SessionStart": [{
      "hooks": [{ "type": "command", "command": "npx @scotthamilton77/sidekick hook session-start" }]
    }],
    "SessionEnd": [{
      "hooks": [{ "type": "command", "command": "npx @scotthamilton77/sidekick hook session-end" }]
    }],
    "UserPromptSubmit": [{
      "hooks": [{ "type": "command", "command": "npx @scotthamilton77/sidekick hook user-prompt-submit" }]
    }],
    "PreToolUse": [{
      "hooks": [{ "type": "command", "command": "npx @scotthamilton77/sidekick hook pre-tool-use" }]
    }],
    "PostToolUse": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "npx @scotthamilton77/sidekick hook post-tool-use" }]
    }],
    "Stop": [{
      "hooks": [{ "type": "command", "command": "npx @scotthamilton77/sidekick hook stop" }]
    }],
    "PreCompact": [{
      "hooks": [{ "type": "command", "command": "npx @scotthamilton77/sidekick hook pre-compact" }]
    }]
  },
  "statusLine": {
    "type": "command",
    "command": "npx @scotthamilton77/sidekick statusline --hook"
  }
}
