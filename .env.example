# LLM Provider API Keys
# Sidekick uses OpenRouter by default - configure in .sidekick/llm.yaml

# OpenRouter (default provider for Sidekick)
OPENROUTER_API_KEY="sk-or-v1-..."

# OpenAI (alternative provider)
OPENAI_API_KEY="sk-proj-..."

# GitHub (for bd sync and GitHub features)
GITHUB_API_KEY="ghp_... or github_pat_..."
