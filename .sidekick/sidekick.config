# ==============================================================================
# Sidekick Configuration
# Generated by: scripts/copy-config.sh
# Override values as needed - see docs/design/CONFIG-SYSTEM.md for details
# ==============================================================================

# ------------------------------------------------------------------------------
# Core
# ------------------------------------------------------------------------------
#core.logging.level=debug
core.development.enabled=true
#core.supervisor.idleTimeoutMs=10000

# ------------------------------------------------------------------------------
# LLM
# ------------------------------------------------------------------------------
# Enable debug dump of LLM requests/responses to session directory
llm.global.debugDumpEnabled=true

# ------------------------------------------------------------------------------
# Reminders Feature
# Automatic reminders when Claude has been working without user input
# ------------------------------------------------------------------------------

# Enable or disable the reminders feature
features.reminders.enabled=true

# Tool calls per turn that trigger the "pause and reflect" reminder.
# Counts tool invocations since the last user prompt (toolsThisTurn metric).
# Fires when: toolsThisTurn >= pause_and_reflect_threshold
#features.reminders.settings.pause_and_reflect_threshold: 1

# ------------------------------------------------------------------------------
# Session Summary Feature - Personas
# For testing persona allow-list behavior
# See docs/design/PERSONA-PROFILES-DESIGN.md
# ------------------------------------------------------------------------------
#features.session-summary.settings.personas.allowList=

# Set high to consider recent sessions fresh (shows resume message)
features.session-summary.settings.personas.resumeFreshnessHours=0
#features.session-summary.settings.personas.injectPersonaIntoClaude=true
#features.session-summary.settings.personas.blockList="disabled,bones,agent-smith,hal"