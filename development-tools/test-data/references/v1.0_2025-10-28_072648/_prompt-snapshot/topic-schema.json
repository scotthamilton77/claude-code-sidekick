{
  "name": "topic_analysis",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "task_ids": {
        "type": ["string", "null"],
        "description": "Task identifiers"
      },
      "initial_goal": {
        "type": "string",
        "description": "User's first stated goal",
        "maxLength": 60
      },
      "current_objective": {
        "type": "string",
        "description": "Current objective being pursued",
        "maxLength": 60
      },
      "clarity_score": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10,
        "description": "Objective clarity rating"
      },
      "confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Analysis confidence"
      },
      "high_clarity_snarky_comment": {
        "type": ["string", "null"],
        "description": "Sarcastic comment for clear conversations",
        "maxLength": 120
      },
      "low_clarity_snarky_comment": {
        "type": ["string", "null"],
        "description": "Prompt for unclear conversations",
        "maxLength": 120
      },
      "significant_change": {
        "type": "boolean",
        "description": "Topic changed meaningfully since baseline"
      }
    },
    "required": [
      "task_ids",
      "initial_goal",
      "current_objective",
      "clarity_score",
      "confidence",
      "high_clarity_snarky_comment",
      "low_clarity_snarky_comment",
      "significant_change"
    ],
    "additionalProperties": false
  }
}
