{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./",
    "paths": {
      "@sidekick/types": ["packages/types/dist"],
      "@sidekick/core": ["packages/sidekick-core/dist"],
      "@sidekick/shared-providers": ["packages/shared-providers/dist"],
      "@sidekick/testing-fixtures": ["packages/testing-fixtures/dist"],
      "@sidekick/feature-session-summary": ["packages/feature-session-summary/dist"],
      "@sidekick/feature-reminders": ["packages/feature-reminders/dist"],
      "@sidekick/feature-statusline": ["packages/feature-statusline/dist"]
    }
  }
}
