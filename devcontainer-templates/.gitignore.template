# DevContainer Environment Files
# Copy this to your project root .gitignore when using these templates

# Environment variables (contains secrets)
.devcontainer/.env

# User-specific IDE settings (if not already ignored)
.vscode/settings.json
.idea/

# OS-specific files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/
jspm_packages/

# Python virtual environments (if using node-ai-stack)
venv/
env/
.venv/
__pycache__/
*.py[cod]

# Build outputs
dist/
build/
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/
