# AI Stack DevContainer Configuration
# Copy this file to .env and customize for your setup

# ============================================================================
# OPTIONAL MOUNTS (Comment out what you don't need)
# ============================================================================

# Claude Code configuration directory (uses ${localEnv:HOME} from host)
# MOUNT_CLAUDE_CONFIG=true

# External OSS projects directory (uses ${localEnv:HOME}/projects/oss by default)
# MOUNT_OSS_PROJECTS=true
# OSS_PROJECTS_PATH=projects/oss

# Specific OSS project mounts (uncomment and customize)
# OSS_PROJECT_1=zen-mcp-server
# OSS_PROJECT_2=claude-code-tamagotchi

# ============================================================================
# DATABASE CONFIGURATION (Optional)
# ============================================================================

# PostgreSQL Connection
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=myapp_dev
# POSTGRES_USER=myapp_user
# POSTGRES_PASSWORD=your_password

# Docker Network (for connecting to external PostgreSQL container)
# DOCKER_NETWORK=postgres_default

# ============================================================================
# AI TOOL INSTALLATION (Optional - set to "true" to install)
# ============================================================================

# Install Claude Code CLI
INSTALL_CLAUDE_CODE=false

# Install Google Gemini CLI
INSTALL_GEMINI_CLI=false

# Install OpenAI Codex CLI
INSTALL_CODEX_CLI=false

# Install uv (Rust-based Python package manager)
INSTALL_UV=false

# Install specify-cli from GitHub
INSTALL_SPECIFY_CLI=false

# Python version to install via uv (if INSTALL_UV=true)
PYTHON_VERSION=3.12.3

# ============================================================================
# API KEYS (Pass through from host environment)
# ============================================================================
# Set these in your host shell environment, not here
# export ANTHROPIC_API_KEY=your_key
# export OPENAI_API_KEY=your_key
# export GOOGLE_API_KEY=your_key
# etc.

# ============================================================================
# PORT FORWARDING (Customize as needed)
# ============================================================================

# Web application port
WEB_APP_PORT=3000

# PostgreSQL port
POSTGRES_FORWARD_PORT=5432
