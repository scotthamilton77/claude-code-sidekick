#!/usr/bin/env bash
# Dev-mode hook wrapper for SessionEnd
# Uses $CLAUDE_PROJECT_DIR for Docker volume mount compatibility
#
# Hook input JSON is piped via stdin to the CLI, which extracts session_id
# per CLI.md §3.1.1 Hook Input Structure.
#
# Environment variables:
#   SIDEKICK_LOG_LEVEL - Override log level (debug|info|warn|error)
set -euo pipefail

CLI_BIN="${CLAUDE_PROJECT_DIR}/packages/sidekick-cli/dist/bin.js"

if [[ ! -f "${CLI_BIN}" ]]; then
  echo "ERROR: CLI not built. Run 'pnpm build' first." >&2
  echo '{"error": "dev-hooks: CLI not built"}' >&2
  exit 1
fi

# Build CLI args
CLI_ARGS=(session-end --hook --scope=project)
CLI_ARGS+=(--hook-script-path="${CLAUDE_PROJECT_DIR}/scripts/dev-hooks/session-end")
CLI_ARGS+=(--project-dir="${CLAUDE_PROJECT_DIR}")
if [[ -n "${SIDEKICK_LOG_LEVEL:-}" ]]; then
  CLI_ARGS+=(--log-level "${SIDEKICK_LOG_LEVEL}")
fi

# Capture stdin first (Claude Code hook input JSON)
STDIN_DATA=$(cat)

# Pass stdin to CLI, then translate internal format to Claude Code format
INTERNAL_RESPONSE=$(echo "$STDIN_DATA" | node "${CLI_BIN}" "${CLI_ARGS[@]}")

# Translate internal HookResponse to Claude Code SessionEnd format
# SessionEnd is a notification hook - uses common fields only
# See: https://code.claude.com/docs/en/hooks
if command -v jq &> /dev/null; then
  echo "$INTERNAL_RESPONSE" | jq -c '
    # SessionEnd cannot block - just pass through or empty
    {}
  '
else
  # Fallback: passthrough if jq not available
  echo "$INTERNAL_RESPONSE"
fi
