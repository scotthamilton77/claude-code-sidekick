#!/usr/bin/env bash
# Dev-mode hook wrapper for UserPromptSubmit
# Uses $CLAUDE_PROJECT_DIR for Docker volume mount compatibility
#
# Hook input JSON is piped via stdin to the CLI, which extracts session_id
# per CLI.md §3.1.1 Hook Input Structure.
set -euo pipefail

CLI_BIN="${CLAUDE_PROJECT_DIR}/packages/sidekick-cli/dist/bin.js"

if [[ ! -f "${CLI_BIN}" ]]; then
  echo "ERROR: CLI not built. Run 'pnpm build' first." >&2
  echo '{"error": "dev-hooks: CLI not built"}' >&2
  exit 1
fi

# Capture stdin and pass to CLI, then translate internal format to Claude Code format
INTERNAL_RESPONSE=$(node "${CLI_BIN}" user-prompt-submit \
  --hook \
  --scope=project \
  --hook-script-path="${CLAUDE_PROJECT_DIR}/scripts/dev-hooks/user-prompt-submit" \
  --project-dir="${CLAUDE_PROJECT_DIR}")

# Translate internal HookResponse to Claude Code UserPromptSubmit format
# - blocking/reason → continue: false, stopReason
# - userMessage → systemMessage (shown to user)
# - additionalContext → hookSpecificOutput.additionalContext
# See: https://code.claude.com/docs/en/hooks
if command -v jq &> /dev/null; then
  echo "$INTERNAL_RESPONSE" | jq -c '
    {}
    + (if .blocking == true then { decision: "block", reason: (.reason // "Blocked by Sidekick") } else {} end)
    + (if .userMessage then { systemMessage: .userMessage } else {} end)
    + (if .additionalContext then { hookSpecificOutput: { hookEventName: "UserPromptSubmit", additionalContext: .additionalContext } } else {} end)
  '
else
  # Fallback: passthrough if jq not available
  echo "$INTERNAL_RESPONSE"
fi
