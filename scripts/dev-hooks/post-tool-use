#!/usr/bin/env bash
# Dev-mode hook wrapper for PostToolUse
# Uses unified 'sidekick hook' command which handles Claude Code format translation
#
# Environment variables:
#   SIDEKICK_LOG_LEVEL - Override log level (debug|info|warn|error)
set -euo pipefail

CLI_BIN="${CLAUDE_PROJECT_DIR}/packages/sidekick-cli/dist/bin.js"

if [[ ! -f "${CLI_BIN}" ]]; then
  echo "ERROR: CLI not built. Run 'pnpm build' first." >&2
  exit 1
fi

# Build CLI args for unified hook command
CLI_ARGS=(hook post-tool-use --project-dir="${CLAUDE_PROJECT_DIR}")
if [[ -n "${SIDEKICK_LOG_LEVEL:-}" ]]; then
  CLI_ARGS+=(--log-level "${SIDEKICK_LOG_LEVEL}")
fi

# exec inherits stdin - unified hook command reads input and outputs Claude Code format
exec node "${CLI_BIN}" "${CLI_ARGS[@]}"
