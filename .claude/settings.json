{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sidekick/sidekick.sh --no-console-logging session-start \"$CLAUDE_PROJECT_DIR\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sidekick/sidekick.sh --no-console-logging user-prompt-submit \"$CLAUDE_PROJECT_DIR\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sidekick/sidekick.sh --no-console-logging post-tool-use \"$CLAUDE_PROJECT_DIR\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sidekick/sidekick.sh --no-console-logging stop \"$CLAUDE_PROJECT_DIR\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sidekick/sidekick.sh --no-console-logging statusline --project-dir \"$CLAUDE_PROJECT_DIR\""
  }
}
