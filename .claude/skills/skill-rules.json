{
    "version": "1.0",
    "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "typescript-cli-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Building production-ready CLI applications with TypeScript",
            "promptTriggers": {
                "keywords": [
                    "CLI",
                    "command line",
                    "command-line",
                    "terminal tool",
                    "CLI tool",
                    "CLI app",
                    "argv",
                    "yargs",
                    "commander",
                    "chalk",
                    "ora",
                    "inquirer",
                    "prompts",
                    "cli-progress",
                    "argument parsing",
                    "argv parsing",
                    "terminal UI",
                    "spinner",
                    "progress bar",
                    "interactive prompt",
                    "stdin",
                    "stdout",
                    "stderr",
                    "exit code",
                    "package.json bin"
                ],
                "intentPatterns": [
                    "(build|create|develop|implement|add|write).*?(CLI|command.?line|terminal).*?(tool|app|application|interface)",
                    "(parse|handle|process).*?(arguments|argv|flags|options|commands)",
                    "(add|create|implement|show).*?(spinner|progress|interactive|prompt|colored?.output)",
                    "(make|create|build).*?(executable|binary|CLI).*?(npm|package)",
                    "(read|handle|process).*?(stdin|stdout|stderr)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/cli.ts",
                    "**/cli.js",
                    "bin/**/*.ts",
                    "bin/**/*.js",
                    "src/cli/**/*.ts"
                ]
            }
        },
        "typescript-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "TypeScript best practices including dependency management with training-cutoff awareness, repository structure for single-project and monorepos, ESLint and Prettier configuration, compiler issue resolution, SOLID principles, type safety patterns, generics, discriminated unions, error handling, and testing strategies",
            "promptTriggers": {
                "keywords": [
                    "TypeScript",
                    "typescript",
                    "tsconfig",
                    "tsconfig.json",
                    "dependencies",
                    "dependency management",
                    "npm",
                    "pnpm",
                    "package.json",
                    "monorepo",
                    "workspace",
                    "workspaces",
                    "nx",
                    "turborepo",
                    "lerna",
                    "eslint",
                    "prettier",
                    "linting",
                    "lint errors",
                    "compiler errors",
                    "type errors",
                    "tsc",
                    "SOLID",
                    "SOLID principles",
                    "single responsibility",
                    "open closed",
                    "liskov substitution",
                    "interface segregation",
                    "dependency inversion",
                    "generics",
                    "type guard",
                    "discriminated union",
                    "utility types",
                    "mapped types",
                    "conditional types",
                    "strict mode",
                    "type safety",
                    "module resolution",
                    "path mapping",
                    "context7",
                    "training cutoff",
                    "post-cutoff"
                ],
                "intentPatterns": [
                    "(setup|configure|create|initialize).*?(typescript|tsconfig|project)",
                    "(fix|resolve|debug).*?(compiler|type|lint|typescript).*?(error|issue)",
                    "(configure|setup|add).*?(eslint|prettier|linting)",
                    "(manage|update|install).*?(dependencies|packages)",
                    "(setup|create|configure).*?(monorepo|workspace)",
                    "(implement|apply|follow|use).*?(SOLID|principles|pattern)",
                    "(create|write|implement).*?(generic|type.?guard|discriminated.?union)",
                    "(optimize|improve|enhance).*?(type.?safety|types|typescript)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/tsconfig.json",
                    "**/tsconfig.*.json",
                    "**/.eslintrc.*",
                    "**/eslint.config.*",
                    "**/.prettierrc*",
                    "**/prettier.config.*"
                ]
            }
        }
    }
}
